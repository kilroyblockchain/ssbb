{
  "name": "ssbb",
  "version": "0.1.0",
  "private": true,
  "description": "Screaming Smoldering Butt Bitches collaboration space",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npm-run-all -p dev:web dev:server",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:server": "npm --workspace apps/server run dev",
    "build": "npm-run-all build:web build:server",
    "build:web": "npm --workspace apps/web run build",
    "build:server": "npm --workspace apps/server run build",
    "lint": "npm-run-all lint:web lint:server",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:server": "npm --workspace apps/server run lint"
  },
  "workspaces": [
    "apps/web",
    "apps/server"
  ],
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
